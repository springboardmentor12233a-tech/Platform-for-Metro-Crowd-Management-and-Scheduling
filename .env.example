# ─────────────────────────────────────────────────────────────────────────────
# AI MetroFlow - Environment Variables Template
# Copy this file to '.env' and modify the values for your active environment.
# ─────────────────────────────────────────────────────────────────────────────

# Backend & Server Configuration
HOST=0.0.0.0
PORT=8000

# Security (JWT Authentication Token Secret)
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET=supersecretkey_metroflow_2026_change_me

# MongoDB Database Configuration
# Local Development URI: mongodb://localhost:27017
# MongoDB Atlas Production URI: mongodb+srv://<username>:<password>@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=metroflow_db
