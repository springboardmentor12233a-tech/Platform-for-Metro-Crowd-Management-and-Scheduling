# ── MetroFlow Backend Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/metroflow

# JWT Secret (generate a strong random string for production)
SECRET_KEY=metroflow-dev-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
FRONTEND_URL=http://localhost:3000

# App
DEBUG=True
